{% block _customer_user_page_widget %}
    {% set attr = layout_attr_defaults(attr, {
        '~class': ' customer-user-form',
        'data-focusable': true,
    }) %}
    <div{{ block('block_attributes') }}>{{ block_widget(block) }}</div>
{% endblock %}

{% block __oro_customer_user_email_form__customer_user_form_fields_widget %}
    {% do block|merge_context({
        'form': form,
    }) %}
    {{ block('container_widget') }}
    {{ form_row(form._token) }}
{% endblock %}

{% block __oro_customer_user_email_form__customer_user_form_fields_email_widget %}
    {% import '@OroUI/layouts/renderIcon.html.twig' as renderIcon %}
    <div class="form-group">
        <div class="grid">
            {% if form.newEmailAddress is defined %}
            <div class="grid-col-6 grid-col-mobile-landscape-12 grid-start-1">
                {{ form_row(form.newEmailAddress, {'attr': {'placeholder': 'oro.customer.form.placeholder.new_email'|trans}}) }}
            </div>
            <div class="grid-col-6 grid-col-mobile-landscape-12 grid-start-1">
                {{ 'oro.customer.controller.customeruser.profile_email_change.hint'|trans({'%current_email%': form.vars.value.email})|raw }}
            </div>
            {% endif %}
            {% if form.email is defined %}
                <div class="grid-col-6 grid-col-mobile-landscape-12 grid-start-1">
                    {{ form_row(form.email, {'attr': {'placeholder': 'oro.customer.form.placeholder.email'|trans}}) }}
                </div>
            {% endif %}
            <div class="grid-col-6 grid-col-mobile-landscape-12 grid-start-1">
                {{ form_row(form.currentPassword, {'attr': {'placeholder': 'oro.customer.form.placeholder.current_password'|trans}, 'parentClass': 'current_password'}) }}
            </div>
        </div>
    </div>
{% endblock %}

{% block __oro_customer_user_email_form__customer_user_form_actions_widget %}
    <div class="form-buttons">
        {{ block_widget(block) }}
    </div>
{% endblock %}
